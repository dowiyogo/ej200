# ============================================================
# run.mac — standard production run
# Usage: ./ej200_bar_sim -m macros/run.mac
# ============================================================

/control/verbose 0
/run/verbose     0
/event/verbose   0
/tracking/verbose 0

/run/initialize

/gun/particle  mu-
/gun/energy    1 GeV
/gun/position  0 60 0 mm
/gun/direction 0 -1 0

/run/beamOn 1000
