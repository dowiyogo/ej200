# ============================================================
# scan.mac — longitudinal scan along the bar (x-axis)
# Usage: ./ej200_bar_sim -m macros/scan.mac
# ============================================================

/control/verbose 0
/run/verbose     0
/event/verbose   0
/tracking/verbose 0

/run/initialize

/gun/particle  mu-
/gun/energy    1 GeV
/gun/direction 0 -1 0

# Loop: 21 positions from -650 to +650 mm, step 65 mm
/control/loop macros/scan_step.mac xpos -650 650 65
