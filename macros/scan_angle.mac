# ============================================================
# scan_angle.mac — angular scan: fixed midpoint, θ from -30° to +30°
# Usage: ./ej200_bar_sim -m macros/scan_angle.mac
#
# The muon is placed at the midpoint between top SiPMs 9 and 10
# (central gap of the bar) and the incidence angle is swept.
# ============================================================

/control/verbose 0
/run/verbose     0
/event/verbose   0
/tracking/verbose 0

/run/initialize

/gun/particle  mu-
/gun/energy    1 GeV

# Fix gun position at midpoint of top SiPMs 9 and 10
/muon/midpointSiPMs 9 10

# Sweep angle from -30 to +30 degrees in 5-degree steps
# scan_angle_step.mac receives alias {angle}
/control/loop macros/scan_angle_step.mac angle -30 30 5
